# ===== ตัวอย่าง environment variables =====
# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (จาก Supabase → Project Settings → API)
# ⚠️ .env.local ห้ามขึ้น GitHub (อยู่ใน .gitignore แล้ว) — ไฟล์ .env.example นี้ขึ้นได้ (ไม่มีค่าจริง)

# --- Supabase (ฝั่ง server / ใช้ตอน backend) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=          # ความลับ — server-only เท่านั้น ห้ามส่งไป client/public
SUPABASE_JWKS_URL=

# --- Supabase (ฝั่ง client / Next.js — แอปจริงใน web/) ---
# ตัวที่ขึ้นต้น NEXT_PUBLIC_ จะถูกฝังในโค้ดฝั่ง browser ได้ (ใช้เฉพาะ key ที่เปิดเผยได้)
# ใช้ naming publishable (key รุ่นใหม่ sb_publishable_... — anon เลิกใช้สิ้นปี 2026)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
